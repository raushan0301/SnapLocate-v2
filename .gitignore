# =============================================
#          SnapLocate — .gitignore
#      Strict & Project-Specific Rules
# =============================================
# Tech stack: Vanilla HTML/CSS/JS
#             Amazon S3 · CloudFront · EC2
#             CloudWatch · IAM · Node.js · macOS
# Region: ap-south-1 (Asia Pacific — Mumbai)
# =============================================


# -----------------------------------------------
# 📝 Markdown / Documentation Files
#    All .md files stay LOCAL — never pushed.
#    Exception: README.md is always tracked.
# -----------------------------------------------
*.md
!README.md


# -----------------------------------------------
# 🗄️ Database & Migration Scripts
# -----------------------------------------------
*.sql
*.mjs
*.db
*.sqlite
*.sqlite3


# -----------------------------------------------
# 🍎 macOS System Files
# -----------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Icon?
*.swp
*.swo
*.bak
*~


# -----------------------------------------------
# ☁️ AWS Credentials & Config
#    CRITICAL: Never commit AWS keys or secrets.
#    AWS CLI stores them safely in ~/.aws/
# -----------------------------------------------

# AWS credentials & config (usually in ~/.aws/ but ignore if copied locally)
.aws/
aws-credentials
credentials
aws-config

# EC2 SSH key pairs — NEVER commit .pem files
*.pem
*.ppk

# AWS exports (generated by Amplify CLI)
aws-exports.js
amplifyconfiguration.json
amplifyconfiguration.dart

# AWS SAM / CloudFormation local build artifacts
.aws-sam/
samconfig.toml
packaged.yaml
packaged-template.yaml

# AWS CDK
cdk.out/
cdk.context.json

# Serverless Framework
.serverless/
serverless.yml.bak

# Elastic Beanstalk
.elasticbeanstalk/
*.zip

# AWS CodeBuild / CodePipeline
buildspec.yml.local


# -----------------------------------------------
# 🌿 Environment Variables & Secrets
# -----------------------------------------------
.env
.env.local
.env.development
.env.production
.env.staging
.env.test
*.key
*.cert
*.p12
secrets.json
service-account.json
credentials.json
config.json.local
config.local.json


# -----------------------------------------------
# 🔐 Firebase Secrets (Legacy — kept gitignored)
#    firebase-config.js held real API keys.
#    Template version is safe to commit.
# -----------------------------------------------
Public/js/core/firebase-config.js
.firebase/
firestore.rules
firestore.indexes.json
.firebaserc
.dataconnect/
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
ui-debug.log


# -----------------------------------------------
# 📦 Node.js / npm
# -----------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.npm/
.yarn-integrity
.yarn/cache
.yarn/unplugged
.pnp.*
*.tgz
package-lock.json


# -----------------------------------------------
# 🛠️ Development & Agent Files
#    Local-only scratch work, AI agent state,
#    and one-off test scripts.
# -----------------------------------------------
_dev_files/
.agent/
.claude/
test-*.js


# -----------------------------------------------
# 🔒 Sensitive & Verification Assets
#    Site verification tokens must never be
#    exposed in a public repository.
# -----------------------------------------------
Public/assets/verification/


# -----------------------------------------------
# ⚙️ Editor & IDE
# -----------------------------------------------
.vscode/
.idea/
*.code-workspace
.history/
*.suo
*.ntvs*
*.njsproj
*.sln
.vs/


# -----------------------------------------------
# 🧪 Testing & Coverage
# -----------------------------------------------
coverage/
.nyc_output/
.grunt/
lib-cov/
test-results/
*.lcov


# -----------------------------------------------
# 🏗️ Build Artifacts & Cache
# -----------------------------------------------
dist/
build/
build/Release
.cache/
.parcel-cache/
.turbo/
.eslintcache
.stylelintcache
*.pid
*.seed
*.pid.lock
.lock-wscript
.node_repl_history
bower_components/


# -----------------------------------------------
# 📋 Logs
# -----------------------------------------------
logs/
*.log
pids/


# -----------------------------------------------
# 🌐 Browser / OS Thumbnails
# -----------------------------------------------
Thumbs.db
Desktop.ini
